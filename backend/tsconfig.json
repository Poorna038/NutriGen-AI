{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true,

    "types": ["node"],
    "resolveJsonModule": true,

    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}